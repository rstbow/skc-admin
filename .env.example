# SKU Compass Admin — environment variables
# Copy to .env locally; set in Azure App Service Configuration for prod.

# Admin DB (skc-admin on vs-ims.database.windows.net)
ADMIN_DB_SERVER=vs-ims.database.windows.net
ADMIN_DB_DATABASE=skc-admin
ADMIN_DB_USER=
ADMIN_DB_PASSWORD=
ADMIN_DB_ENCRYPT=true
ADMIN_DB_TRUST_CERT=false

# JWT signing
JWT_SECRET=change-me-in-production-use-64-char-random
JWT_EXPIRES_IN=8h

# Credential encryption (AES-256-GCM) — 32-byte hex string (64 hex chars)
CRED_ENCRYPTION_KEY=change-me-32-byte-hex-key

# Server
PORT=8080
NODE_ENV=development
